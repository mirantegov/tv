# Config por tenant. Copie para .env.<slug> (ex.: .env.palotina) e ajuste.
# Uso: docker compose --env-file .env.palotina -p palotina up -d --build
# NÃO comitar os .env.<slug> reais (contêm senha) — só este .env.example.

# --- Identidade do tenant (id_tenant = código IBGE do município) ---
TENANT_ID=4118402
TENANT_SLUG=palotina
TENANT_NOME=Município de Palotina
TENANT_UF=PR

# --- Banco (Postgres) ---
POSTGRES_USER=mirante
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=mirante_palotina

# --- Portas locais (parametrizadas p/ rodar vários tenants na mesma máquina) ---
WEB_PORT=8080
DB_PORT=5432

# --- API (PostgREST) — preenchido no Milestone 2 ---
# API_URL=http://localhost:3000
# PGRST_PORT=3000
