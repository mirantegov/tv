# ============================================================================
# Deploy por tenant — Mirante Gov  (roadmap: OpenTofu + GitHub Actions)
#
# Copie para .env.<slug> (ex.: .env.palotina), preencha os segredos e rode o
# deploy. NÃO comite o arquivo preenchido — só este .example é versionado.
#
#   Endereço final:  https://<TENANT_SLUG>.tv.mirantegov.cloud
#   Provisiona VPS:  OpenTofu (AWS)      DNS + TLS:  Cloudflare
#   Build + deploy:  GitHub Actions      Imagem web: GHCR
# ============================================================================

# --- Identidade do tenant --------------------------------------------------
TENANT_SLUG=palotina                  # vira o subdomínio: <slug>.tv.mirantegov.cloud
TENANT_NOME=Município de Palotina
TENANT_UF=PR
TENANT_ID=4117909                     # código IBGE (id_tenant)

# --- Domínio / TLS ---------------------------------------------------------
BASE_DOMAIN=tv.mirantegov.cloud       # host completo = <TENANT_SLUG>.<BASE_DOMAIN>
ACME_EMAIL=                           # e-mail p/ emissão do certificado TLS (Let's Encrypt)

# --- AWS  (OpenTofu provisiona a VPS) --------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=sa-east-1                  # São Paulo
AWS_INSTANCE_TYPE=t3.small           # 2 vCPU / 2 GB — ajuste conforme a carga
AWS_SSH_KEY_NAME=                     # nome do key pair já cadastrado na AWS
SSH_PUBLIC_KEY=                       # chave pública p/ acesso à VPS (vai no authorized_keys)

# --- Cloudflare  (registro DNS de *.tv.mirantegov.cloud) -------------------
CLOUDFLARE_API_TOKEN=                 # token com permissão de editar DNS da zona
CLOUDFLARE_ZONE_ID=                   # zone id de "mirantegov.cloud"

# --- GitHub  (Actions faz build/deploy; imagem publicada no GHCR) ----------
GITHUB_TOKEN=                         # PAT/Actions token com acesso ao repo + GHCR
GITHUB_REPOSITORY=mirantegov/tv
IMAGE_TAG=latest                      # tag da imagem web a implantar

# --- Banco (Postgres do tenant, em container na VPS) -----------------------
POSTGRES_USER=mirante
POSTGRES_PASSWORD=                    # SENHA FORTE — gere uma diferente por tenant
POSTGRES_DB=mirante_palotina

# --- API (PostgREST) -------------------------------------------------------
# Em produção o proxy reverso roteia  /  -> web  e  /api -> PostgREST, então:
#   API_URL = https://<TENANT_SLUG>.tv.mirantegov.cloud/api
# (derivado no deploy a partir de TENANT_SLUG + BASE_DOMAIN — não preencher aqui)

# --- Data warehouse (ClickHouse) — ingestão noturna ------------------------
# Fonte externa (outra instância) de onde o job noturno recria os dados do
# tenant (TRUNCATE + COPY). Deixe em branco enquanto usar o seed de data.ts.
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8443
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=
# Horário do job (cron, no fuso da VPS). Padrão: 03:00.
INGEST_CRON=0 3 * * *
