# ============================================================================
# Data warehouse — Mirante Gov  (máquina SEPARADA do app)
#
# Copie para .env.warehouse, preencha os segredos e NÃO comite o arquivo
# preenchido — só este .example é versionado.
#
#   Máquina:  EC2 m7i.2xlarge (x86_64, 8 vCPU / 32 GB), us-east-1
#   Endereço: dw.tv.mirantegov.cloud
#   Hospeda:  ClickHouse (fonte da ETL noturna dos tenants) + Postgres
#             (ETL futura + Dashboards paralelo)
# ============================================================================

# --- Domínio ---------------------------------------------------------------
BASE_DOMAIN=tv.mirantegov.cloud
ACME_EMAIL=

# --- AWS  (OpenTofu provisiona a VPS) --------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
SSH_PUBLIC_KEY=                       # chave pública p/ acesso à VPS

# --- Rede / acesso aos bancos ----------------------------------------------
ADMIN_CIDR=0.0.0.0/0                  # seu IP/32 — SSH + admin dos bancos
APP_CIDR=0.0.0.0/0                    # EIP da VPS do app/32 — acesso ClickHouse/Postgres

# --- Cloudflare  (registro DNS de dw.tv.mirantegov.cloud) ------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- GitHub  (host clona o repo em /opt/mirante) ---------------------------
GITHUB_TOKEN=
GITHUB_REPOSITORY=mirantegov/tv

# --- ClickHouse (DW / fonte da ETL noturna) --------------------------------
# Portas: HTTP 8123, native 9000.
CLICKHOUSE_USER=mirante
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=mirante_dw

# --- Postgres do warehouse (ETL futura + Dashboards) -----------------------
# Vars PGWH_* p/ não colidir com o POSTGRES_* dos tenants. Porta 5432.
PGWH_USER=mirante
PGWH_PASSWORD=
PGWH_DB=dashboards
